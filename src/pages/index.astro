---
// digid.co — Management Consulting for Tech
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="digid.co — Management Consulting for Tech" />
    <title>digid.co</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --color-bg:      #ffffff;
        --color-primary: #231f20;
        --color-muted:   #6b6869;
        --color-border:  #e8e7e7;
        --font-family:   'Inter', system-ui, sans-serif;
      }

      html {
        background: var(--color-bg);
        color: var(--color-primary);
        font-family: var(--font-family);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        scroll-behavior: smooth;
      }

      body {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }

      /* ── Hero ── */
      .hero {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100dvh;
        padding: 4rem 2rem 8rem;
        gap: 2.5rem;
        text-align: center;
      }

      .hero__logo {
        display: block;
        width: 180px;
        height: auto;
        opacity: 0.97;
      }

      .hero__tagline {
        font-size: clamp(0.9rem, 2.5vw, 1.1rem);
        font-weight: 300;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--color-primary);
        opacity: 0.75;
      }

      .hero__contact {
        margin-top: 0.5rem;
        font-size: 0.875rem;
        font-weight: 400;
        letter-spacing: 0.04em;
      }

      .hero__contact a {
        color: var(--color-primary);
        text-decoration: none;
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 1px;
        transition: border-color 0.2s ease, opacity 0.2s ease;
        opacity: 0.55;
      }

      .hero__contact a:hover {
        border-color: var(--color-primary);
        opacity: 1;
      }

      /* ── Footer ── */
      footer {
        width: 100%;
        padding: 1.25rem 2rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .footer__text {
        font-size: 0.7rem;
        font-weight: 400;
        color: var(--color-muted);
        letter-spacing: 0.02em;
        line-height: 1.6;
        max-width: 780px;
      }

      /* ── Fade-in animation ── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0);    }
      }

      .hero__logo     { animation: fadeUp 0.8s ease both; animation-delay: 0.1s; }
      .hero__tagline  { animation: fadeUp 0.8s ease both; animation-delay: 0.3s; }
      .hero__contact  { animation: fadeUp 0.8s ease both; animation-delay: 0.5s; }

      /* ── Responsive tweaks ── */
      @media (max-width: 480px) {
        .hero__logo { width: 140px; }
        .hero__tagline { letter-spacing: 0.14em; }
      }
    </style>
  </head>
  <body>

    <main class="hero">
      <img
        src="/logo.png"
        alt="digid"
        class="hero__logo"
        width="200"
        height="80"
      />

      <p class="hero__tagline">Management Consulting for Tech</p>

      <p class="hero__contact">
        <a href="mailto:hi@digid.co">hi@digid.co</a>
      </p>
    </main>

    <footer>
      <p class="footer__text">
        &copy; 2026 GGKS Assoc. O&Uuml;&nbsp;&middot;&nbsp;digid.co is a trading name of GGKS Assoc.
        O&Uuml;, a private limited company registered in Estonia&nbsp;&middot;&nbsp;All rights reserved
      </p>
    </footer>

  </body>
</html>
