---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import Layout from '../layouts/Layout.astro';

let tagline = 'Management Consulting for Tech';
let contactEmail = 'hi@digid.co';

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  const homepage = await reader.singletons.homepage.read();
  if (homepage) {
    tagline = homepage.tagline || tagline;
    contactEmail = homepage.contactEmail || contactEmail;
  }
} catch {
  // fall back to defaults
}
---
<Layout title="digid.co" description={tagline}>

  <main class="hero">
    <img
      src="/logo.png"
      alt="digid"
      class="hero__logo"
      width="200"
      height="80"
    />
    <p class="hero__tagline">{tagline}</p>
    <p class="hero__contact">
      <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
    </p>
  </main>

</Layout>

<style>
  .hero {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: 4rem 2rem 8rem;
    gap: 2.5rem;
    text-align: center;
  }

  .hero__logo {
    display: block;
    width: 180px;
    height: auto;
    opacity: 0.97;
  }

  .hero__tagline {
    font-size: clamp(0.9rem, 2.5vw, 1.1rem);
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-primary, #231f20);
    opacity: 0.75;
  }

  .hero__contact {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.04em;
  }

  .hero__contact a {
    color: var(--color-primary, #231f20);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border, #e8e7e7);
    padding-bottom: 1px;
    transition: border-color 0.2s ease, opacity 0.2s ease;
    opacity: 0.55;
  }

  .hero__contact a:hover {
    border-color: var(--color-primary, #231f20);
    opacity: 1;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__logo    { animation: fadeUp 0.8s ease both; animation-delay: 0.1s; }
  .hero__tagline { animation: fadeUp 0.8s ease both; animation-delay: 0.3s; }
  .hero__contact { animation: fadeUp 0.8s ease both; animation-delay: 0.5s; }

  @media (max-width: 480px) {
    .hero__logo { width: 140px; }
    .hero__tagline { letter-spacing: 0.14em; }
  }
</style>
