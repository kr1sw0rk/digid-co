---
// This static route takes priority over Keystatic's /keystatic/[...params] catch-all.
// The deploy button uses window.location.href to force a full page load here
// (bypassing Keystatic's client-side SPA router).
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Deploy · digid.co</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:       #111110;
        --surface:  #1c1917;
        --border:   #292524;
        --text:     #e7e5e4;
        --muted:    #78716c;
        --accent:   #f5f5f4;
        --danger:   #ef4444;
        --success:  #22c55e;
        --font:     'Inter', system-ui, sans-serif;
      }

      html, body {
        height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        -webkit-font-smoothing: antialiased;
      }

      body {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
        gap: 0;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 2.5rem 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
      }

      .card__header {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .card__logo {
        height: 20px;
        width: auto;
        opacity: 0.85;
        margin-bottom: 0.25rem;
      }

      .card__title {
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--accent);
        letter-spacing: -0.01em;
      }

      .card__desc {
        font-size: 0.8rem;
        color: var(--muted);
        line-height: 1.6;
      }

      .divider {
        height: 1px;
        background: var(--border);
        margin: 0 -2.5rem;
      }

      .pipeline {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .pipeline__step {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.8rem;
        color: var(--muted);
      }

      .pipeline__icon {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--bg);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        flex-shrink: 0;
      }

      .btn-deploy {
        width: 100%;
        padding: 0.75rem 1.25rem;
        background: var(--accent);
        color: #111;
        border: none;
        border-radius: 8px;
        font-family: var(--font);
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.01em;
        cursor: pointer;
        transition: opacity 0.15s ease, transform 0.1s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
      }

      .btn-deploy:hover:not(:disabled) { opacity: 0.88; }
      .btn-deploy:active:not(:disabled) { transform: scale(0.985); }
      .btn-deploy:disabled { opacity: 0.4; cursor: not-allowed; }

      .status {
        font-size: 0.775rem;
        text-align: center;
        min-height: 1.2em;
        color: var(--muted);
        transition: color 0.2s;
      }
      .status.success { color: var(--success); }
      .status.error   { color: var(--danger); }

      .back {
        margin-top: 1.5rem;
        font-size: 0.75rem;
        color: var(--muted);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        opacity: 0.7;
        transition: opacity 0.15s;
      }
      .back:hover { opacity: 1; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="card__header">
        <img src="/logo.png" alt="digid" class="card__logo" />
        <p class="card__title">Publish to production</p>
        <p class="card__desc">
          Merges all saved changes from <strong style="color: var(--text)">staging</strong>
          into <strong style="color: var(--text)">main</strong> and triggers
          a Cloudflare Pages build.
        </p>
      </div>

      <div class="divider"></div>

      <div class="pipeline">
        <div class="pipeline__step">
          <div class="pipeline__icon">✏️</div>
          <span>Changes saved to <strong>staging</strong> branch</span>
        </div>
        <div class="pipeline__step">
          <div class="pipeline__icon" id="merge-icon">🔀</div>
          <span>Merge <strong>staging → main</strong> via GitHub Actions</span>
        </div>
        <div class="pipeline__step">
          <div class="pipeline__icon" id="deploy-icon">☁️</div>
          <span>Cloudflare Pages rebuilds &amp; deploys</span>
        </div>
      </div>

      <div>
        <button class="btn-deploy" id="deploy-btn">
          <span>🚀</span>
          <span id="btn-label">Deploy to production</span>
        </button>
        <p class="status" id="status-msg"></p>
      </div>
    </div>

    <a href="/keystatic" class="back">← Back to editor</a>

    <script>
      const btn = document.getElementById('deploy-btn');
      const label = document.getElementById('btn-label');
      const status = document.getElementById('status-msg');
      const mergeIcon = document.getElementById('merge-icon');
      const deployIcon = document.getElementById('deploy-icon');

      btn.addEventListener('click', async () => {
        btn.disabled = true;
        label.textContent = 'Triggering deploy…';
        status.className = 'status';
        status.textContent = '';
        mergeIcon.textContent = '⏳';

        try {
          const res = await fetch('/api/deploy', { method: 'POST' });
          const data = await res.json();

          if (!res.ok || !data.ok) {
            throw new Error(data.error || 'Deploy failed');
          }

          mergeIcon.textContent = '✅';
          deployIcon.textContent = '⏳';
          label.textContent = 'Deploy triggered!';
          status.className = 'status success';
          status.textContent = 'GitHub Actions is merging staging → main. Cloudflare will rebuild in ~2 min.';
        } catch (err) {
          mergeIcon.textContent = '❌';
          label.textContent = 'Deploy to production';
          btn.disabled = false;
          status.className = 'status error';
          status.textContent = err.message || 'Something went wrong. Try again.';
        }
      });
    </script>
  </body>
</html>
