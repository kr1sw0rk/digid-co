---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import Layout from '../layouts/Layout.astro';
import DocRenderer from '../components/DocRenderer.tsx';

export async function getStaticPaths() {
  const reader = createReader(process.cwd(), keystaticConfig);
  const slugs = await reader.collections.pages.list();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const reader = createReader(process.cwd(), keystaticConfig);
const entry = await reader.collections.pages.read(slug!);

if (!entry) {
  return Astro.redirect('/');
}

const pageTitle = entry.title.name ?? slug!;
const content = await entry.content();
---
<Layout title={pageTitle} description={pageTitle}>
  <article>
    <h1>{pageTitle}</h1>
    <DocRenderer document={content} />
  </article>
</Layout>

<style>
  article {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  article h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-bottom: 2.5rem;
    color: var(--color-primary, #231f20);
  }

  /* Document content typography */
  article :global(p) {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-primary, #231f20);
    margin-bottom: 1.25rem;
  }

  article :global(h2) {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.01em;
  }

  article :global(h3) {
    font-size: 1.05rem;
    font-weight: 500;
    margin: 2rem 0 0.5rem;
  }

  article :global(ul),
  article :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  article :global(li) {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    margin-bottom: 0.25rem;
  }

  article :global(a) {
    color: var(--color-primary, #231f20);
    border-bottom: 1px solid var(--color-border, #e8e7e7);
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  article :global(a:hover) {
    border-color: var(--color-primary, #231f20);
  }

  article :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border, #e8e7e7);
    margin: 2.5rem 0;
  }

  article :global(strong) { font-weight: 500; }
  article :global(em) { font-style: italic; }

  @media (max-width: 600px) {
    article { padding: 2.5rem 1.25rem 4rem; }
  }
</style>
